# Google Gemini API key from https://aistudio.google.com/apikey
GEMINI_API_KEY=your-google-aistudio-key-here

# Optional text-chat model override. Defaults to gemini-3-flash-preview.
# Cheaper alternative: gemini-3.1-flash-lite-preview
# GEMINI_MODEL=gemini-3-flash-preview

# ── Plate XII · Chart mode (Viz agent) ──────────────────────────
# Model used by the chart agent (Gemini ADK + BuiltInCodeExecutor).
# Must be a code-execution-capable model. Requires a billed Gemini API project.
# VIZ_MODEL=gemini-3.1-pro-preview

# Backend port (must match the proxy target in vite.config.js)
PORT=5175

# ── Voice chat (Plate XII · Voice tab) ───────────────────────────
# Port for the Node/TS live-voice server (live/server.mts).
# Must match the /live proxy target in vite.config.js.
LIVE_PORT=8765
# GEMINI_LIVE_MODEL=gemini-3.1-flash-live-preview
# GEMINI_LIVE_VOICE=Puck

# ── Safety: Google Cloud Model Armor (optional) ──────────────────
# Screens user prompts (text and voice transcripts) before they reach
# Gemini. Leave ANY of these three blank to disable — the chat still
# works, just unscreened. See README "Safety — Model Armor" for setup.
MODEL_ARMOR_PROJECT=
MODEL_ARMOR_LOCATION=us-central1
MODEL_ARMOR_TEMPLATE=
